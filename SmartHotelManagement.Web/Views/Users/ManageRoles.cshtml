@model SmartHotelManagement.Model.ApplicationUser
@{
    ViewData["HeaderTitle"] = "Manage Roles";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Manage Roles";
    var roles = ViewData["Roles"] as IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>;
    var userRoles = ViewData["UserRoles"] as IEnumerable<string>;
}
<div class="row">
    <div class="col-md-12">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">Roles for @Model.Email</h3>
            </div>
            <form class="form-horizontal" asp-action="UpdateRoles" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="card-body">
                    <div class="form-group">
                        @if (roles != null)
                        {
                            foreach (var r in roles)
                            {
                                var checkedAttr = (userRoles != null && userRoles.Contains(r.Name)) ? "checked" : "";
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="role_@r.Name" name="selectedRoles" value="@r.Name" @checkedAttr />
                                    <label class="form-check-label" for="role_@r.Name">@r.Name</label>
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-info">Save</button>
                    <a asp-action="Index" class="btn btn-default float-right">Back to Users</a>
                </div>
            </form>
        </div>
    </div>
</div>
