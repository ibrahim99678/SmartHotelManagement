@model SmartHotelManagement.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}
<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card stat-card sc-primary">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="card-title text-uppercase mb-1">Available Rooms</h6>
                            <h2 class="mb-0">@Model.AvailableRoomsCount</h2>
                        </div>
                        <div class="stat-icon"><i class="fas fa-bed"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card sc-success">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="card-title text-uppercase mb-1">Employees</h6>
                            <h2 class="mb-0">@Model.EmployeeCount</h2>
                        </div>
                        <div class="stat-icon"><i class="fas fa-users"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card sc-warning">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="card-title text-uppercase mb-1">Monthly Sales</h6>
                            <h2 class="mb-0">@Model.MonthlySalesTotal.ToString("C")</h2>
                        </div>
                        <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card sc-info">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="card-title text-uppercase mb-1">Today’s Reservations</h6>
                            <h2 class="mb-0">@Model.TodayReservations.Count</h2>
                        </div>
                        <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Today's Reservations</h5>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Guest</th>
                                <th>Room Type</th>
                                <th>Check-In</th>
                                <th>Check-Out</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.TodayReservations)
                            {
                                <tr>
                                    <td>@(r.Guest != null ? (r.Guest.FirstName + " " + r.Guest.LastName) : "-")</td>
                                    <td>@r.Room?.RoomType?.RoomTypeName</td>
                                    <td>@r.CheckInDate.ToString("g")</td>
                                    <td>@(r.CheckOutDate.HasValue ? r.CheckOutDate.Value.ToString("g") : "-")</td>
                                    <td>@r.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Last 7 Days Reservations</h5>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Guest</th>
                                <th>Room Type</th>
                                <th>Check-In</th>
                                <th>Check-Out</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Last7DaysReservations)
                            {
                                <tr>
                                    <td>@(r.Guest != null ? (r.Guest.FirstName + " " + r.Guest.LastName) : "-")</td>
                                    <td>@r.Room?.RoomType?.RoomTypeName</td>
                                    <td>@r.CheckInDate.ToString("d")</td>
                                    <td>@(r.CheckOutDate.HasValue ? r.CheckOutDate.Value.ToString("d") : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Sales by Room Type</h5>
                </div>
                <div class="card-body">
                    <canvas id="salesPie"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Notes</h5>
                </div>
                <div class="card-body">
                    <p>Figures update based on current reservations and payments recorded during this month.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    (function () {
        var ctx = document.getElementById('salesPie');
        if (!ctx) return;
        var labels = [];
        var values = [];
        @foreach (var kv in Model.MonthlySalesByRoomType)
        {
            @:labels.push("@kv.Key");
            @:values.push(@kv.Value);
        }

        var chart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f', '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ab']
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                var label = context.label || '';
                                var value = context.raw || 0;
                                return label + ': ' + new Intl.NumberFormat(undefined, { style: 'currency', currency: 'USD' }).format(value);
                            }
                        }
                    },
                    legend: { position: 'bottom' }
                }
            }
        });
    })();
</script>
<style>
    .stat-card{color:#fff;border:0;border-radius:.75rem;box-shadow:0 10px 20px rgba(0,0,0,.08)}
    .stat-card .card-body{padding:1rem 1.25rem}
    .stat-icon{font-size:2.25rem;opacity:.9}
    .sc-primary{background:linear-gradient(135deg,#4e54c8,#8f94fb)}
    .sc-success{background:linear-gradient(135deg,#11998e,#38ef7d)}
    .sc-warning{background:linear-gradient(135deg,#f7971e,#ffd200)}
    .sc-info{background:linear-gradient(135deg,#00c6ff,#0072ff)}
    @@media (max-width: 576px){.stat-icon{font-size:1.75rem}}
    .card-title{letter-spacing:.04em}
</style>
