@model SmartHotelManagement.Model.Category
@{
    ViewData["HeaderTitle"] = "Edit Category";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Category Edit";
}
<div class="row">
    <div class="col-md-12">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">Edit Category</h3>
            </div>
            <form class="form-horizontal" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CategoryId" />
                <div class="card-body">
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Name">Name</label>
                        <div class="col-sm-10">
                            <input asp-for="Name" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Kind">Kind</label>
                        <div class="col-sm-10">
                            <select asp-for="Kind" class="form-control">
                                <option value="0">Expense</option>
                                <option value="1">Income</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="ParentCategoryId">Parent</label>
                        <div class="col-sm-10">
                            <select asp-for="ParentCategoryId" class="form-control" asp-items="ViewBag.ParentCategoryId">
                                <option value="">None</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-2"></div>
                        <div class="col-sm-10">
                            <div class="form-check">
                                <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-info">Update</button>
                    <a asp-action="Index" class="btn btn-default float-right">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>
