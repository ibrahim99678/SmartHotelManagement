@model SmartHotelManagement.Model.Employee
@{
    ViewData["HeaderTitle"] = "Delete Employee";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Employees Delete";
}
<div class="row">
    <div class="col-md-12">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">Confirm Delete</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-2">Name</dt>
                    <dd class="col-sm-10">@Model.FirstName @Model.LastName</dd>
                    <dt class="col-sm-2">Email</dt>
                    <dd class="col-sm-10">@Model.Email</dd>
                    <dt class="col-sm-2">Department</dt>
                    <dd class="col-sm-10">@Model.Department</dd>
                    <dt class="col-sm-2">Position</dt>
                    <dd class="col-sm-10">@Model.Position</dd>
                </dl>
            </div>
            <div class="card-footer">
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.EmployeeId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-default float-right">Back to List</a>
                </form>
            </div>
        </div>
    </div>
</div>
