@model SmartHotelManagement.Model.Employee
@{
    ViewData["HeaderTitle"] = "Edit Employee";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Employees Edit";
}
<div class="row">
    <div class="col-md-12">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">Edit Employee</h3>
            </div>
            <form class="form-horizontal" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="EmployeeId" />
                <div class="card-body">
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="FirstName">First Name</label>
                        <div class="col-sm-10">
                            <input asp-for="FirstName" class="form-control" />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="LastName">Last Name</label>
                        <div class="col-sm-10">
                            <input asp-for="LastName" class="form-control" />
                        </div>
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Email">Email</label>
                        <div class="col-sm-10">
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="PhoneNumber">Phone</label>
                        <div class="col-sm-10">
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Department">Department</label>
                        <div class="col-sm-10">
                            <input asp-for="Department" class="form-control" />
                        </div>
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Position">Position</label>
                        <div class="col-sm-10">
                            <input asp-for="Position" class="form-control" />
                        </div>
                        <span asp-validation-for="Position" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" for="UserId">Linked User</label>
                        <div class="col-sm-10">
                            <select id="UserId" name="UserId" class="form-control" asp-items="ViewBag.UserId">
                                <option value="">Select user (optional)</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="HireDate">Hire Date</label>
                        <div class="col-sm-10">
                            <input asp-for="HireDate" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="HireDate" class="text-danger"></span>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-2"></div>
                        <div class="col-sm-10 form-check">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                            <label class="form-check-label" asp-for="IsActive"></label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-info">Save</button>
                    <a asp-action="Index" class="btn btn-default float-right">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
