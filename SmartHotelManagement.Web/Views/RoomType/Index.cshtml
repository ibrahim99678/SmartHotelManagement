@using SmartHotelManagement.Model
@model IEnumerable<RoomType>

@{
    ViewData["HeaderTitle"] = "RoomType";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Room Types List";
}

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <!-- Bootstrap 4 close button -->
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete <strong id="RoomDataTable"></strong>?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<a class="btn btn-primary mb-3" asp-action="create">Add Room Type</a>

<table id="RoomTypeDataTable" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Default Rate</th>
            <th style="width:220px;">Action</th>        
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.RoomTypeName</td>
                <td>@item.DefaultRate</td>

                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.RoomTypeId">Edit</a>
                    <a class="btn btn-sm btn-info" asp-action="ViewDetails" asp-route-id="@item.RoomTypeId">View Details</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.RoomTypeId">Delete</a>
                </td>              
            </tr>
        }
    </tbody>
</table>

@section Scripts{
    <!-- jQuery -->
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables -->
    <script src="~/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
    <script>
        $("#RoomTypeDataTable").DataTable({
            "responsive": true,
            "autoWidth": false,
        });
    </script>

    <!--JS for Delete Modal (use jQuery .on for Bootstrap 4 events)-->
    <script>
        $(function () {
            $('#deleteModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget); // Button that triggered the modal
                var roomTypeId = button.data('id');
                var roomTypeName = button.data('name');

                $('#guestName').text(roomTypeName);

                // Build action using Url.Action to ensure correct controller route
                var baseUrl = '@Url.Action("Delete", "RoomType")'; // e.g. "/RoomType/Delete"
                $('#deleteForm').attr('action', baseUrl + '/' + roomTypeId);
            });
        });
    </script>
}
