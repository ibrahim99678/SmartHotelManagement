@model SmartHotelManagement.Model.Reservation
@{
    ViewData["HeaderTitle"] = "Reservation Details";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Reservation Details";
}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Reservation</h3>
            </div>
            <div class="card-body">
                @{
                    var statusText = ViewData["PaymentStatus"]?.ToString() ?? "Unknown";
                    var statusClass = statusText == "Paid" ? "bg-success" : "bg-danger";
                    var dueText = ViewData["DueAmount"]?.ToString() ?? "0";
                }
                <div class="mb-3">
                    <span class="badge @statusClass">@statusText</span>
                    <span class="badge bg-warning text-dark">Due: @dueText</span>
                </div>
                <dl class="row">
                    <dt class="col-sm-2">Guest</dt>
                    <dd class="col-sm-10">@((Model.Guest != null) ? (Model.Guest.FirstName + " " + Model.Guest.LastName) : "-")</dd>
                    <dt class="col-sm-2">Room</dt>
                    <dd class="col-sm-10">@Model.Room?.RoomNumber</dd>
                    <dt class="col-sm-2">Check In</dt>
                    <dd class="col-sm-10">@Model.CheckInDate.ToShortDateString()</dd>
                    <dt class="col-sm-2">Check Out</dt>
                    <dd class="col-sm-10">@((Model.CheckOutDate.HasValue) ? Model.CheckOutDate.Value.ToShortDateString() : "-")</dd>
                    <dt class="col-sm-2">Nights</dt>
                    <dd class="col-sm-10">@Model.StayInNight</dd>
                    <dt class="col-sm-2">Total</dt>
                    <dd class="col-sm-10">@string.Format("{0:C}", Model.TotalAmount)</dd>
                    <dt class="col-sm-2">Status</dt>
                    <dd class="col-sm-10">@Model.Status</dd>
                </dl>
                <hr />
                <h5>Payment History</h5>
                @{
                    var payments = ViewData["Payments"] as IList<SmartHotelManagement.Model.Payment>;
                }
                <table class="table table-sm table-bordered mb-3">
                    <thead><tr><th>Date</th><th>Amount</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody>
                    @if (payments != null && payments.Count > 0)
                    {
                        foreach (var p in payments)
                        {
                            <tr>
                                <td>@p.PaymentDate.ToString("g")</td>
                                <td>@($"{p.Amount:C}")</td>
                                <td>@p.PaymentType</td>
                                <td>@p.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center">No payments recorded</td></tr>
                    }
                    </tbody>
                </table>
                <h5>Room Change History</h5>
                @{
                    var roomChanges = ViewData["RoomChanges"] as IList<SmartHotelManagement.Model.RoomChange>;
                    var roomMap = ViewBag.RoomMap as System.Collections.Generic.IDictionary<int, string>;
                }
                <table class="table table-sm table-bordered mb-3">
                    <thead><tr><th>Date</th><th>Old Room</th><th>New Room</th><th>Reason</th></tr></thead>
                    <tbody>
                    @if (roomChanges != null && roomChanges.Count > 0)
                    {
                        foreach (var c in roomChanges)
                        {
                            var oldNum = (roomMap != null && roomMap.ContainsKey(c.OldRoomId)) ? roomMap[c.OldRoomId] : c.OldRoomId.ToString();
                            var newNum = (roomMap != null && roomMap.ContainsKey(c.NewRoomId)) ? roomMap[c.NewRoomId] : c.NewRoomId.ToString();
                            <tr>
                                <td>@c.ChangedOn.ToString("g")</td>
                                <td>@oldNum</td>
                                <td>@newNum</td>
                                <td>@c.Reason</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center">No room changes</td></tr>
                    }
                    </tbody>
                </table>
                <h5>Guest Reservations</h5>
                @{
                    var guestRes = ViewData["GuestReservations"] as IList<SmartHotelManagement.Model.Reservation>;
                }
                <table class="table table-sm table-bordered">
                    <thead><tr><th>Reservation</th><th>Room</th><th>In</th><th>Out</th><th>Total</th><th>Status</th></tr></thead>
                    <tbody>
                    @if (guestRes != null && guestRes.Count > 0)
                    {
                        foreach (var r in guestRes)
                        {
                            <tr>
                                <td>@r.ReservationId</td>
                                <td>@r.Room?.RoomNumber</td>
                                <td>@r.CheckInDate.ToShortDateString()</td>
                                <td>@(r.CheckOutDate.HasValue ? r.CheckOutDate.Value.ToShortDateString() : "-")</td>
                                <td>@($"{(r.TotalAmount ?? 0):C}")</td>
                                <td>@r.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center">No other reservations</td></tr>
                    }
                    </tbody>
                </table>
                <hr />
                <h5>Quick Payment</h5>
                <form asp-action="AddPayment" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reservationId" value="@Model.ReservationId" />
                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label for="amount">Amount</label>
                            <input type="number" step="0.01" min="0" class="form-control" id="amount" name="amount" required />
                        </div>
                        <div class="form-group col-md-4">
                            <label for="paymentType">Payment Type</label>
                            <select class="form-control" id="paymentType" name="paymentType">
                                <option value="1">Cash</option>
                                <option value="2">Card</option>
                                <option value="3">BankTransfer</option>
                            </select>
                        </div>
                        <div class="form-group col-md-4" id="bankNameGroup" style="display:none;">
                            <label for="bankName">Bank Name</label>
                            <input type="text" class="form-control" id="bankName" name="bankName" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Record Payment</button>
                </form>
                <hr />
                <h5 class="d-flex align-items-center">
                    <button class="btn btn-warning" type="button" data-toggle="collapse" data-target="#changeRoomPanel" aria-expanded="false" aria-controls="changeRoomPanel">
                        Change Room
                    </button>
                </h5>
                <div class="collapse" id="changeRoomPanel">
                    <form asp-action="ChangeRoom" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reservationId" value="@Model.ReservationId" />
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label for="newRoomId">New Room</label>
                                @{
                                    var availableRooms = ViewData["AvailableRooms"] as SelectList;
                                }
                                <select id="newRoomId" name="newRoomId" class="form-control" asp-items="availableRooms">
                                    <option value="">Select a room</option>
                                </select>
                            </div>
                            <div class="form-group col-md-8">
                                <label for="reason">Reason</label>
                                <input type="text" class="form-control" id="reason" name="reason" placeholder="Reason for room change" required />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-warning">Confirm Change</button>
                    </form>
                </div>
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model?.ReservationId" class="btn btn-info">Edit</a>
                <form asp-action="CompleteReservation" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ReservationId" />
                    <button type="submit" class="btn btn-success">Complete Reservation</button>
                </form>
                <a asp-action="Index" class="btn btn-default float-right">Back to List</a>
            </div>
        </div>
    </div>
</div>
<script>
    (function () {
        var paymentType = document.getElementById('paymentType');
        var bankGroup = document.getElementById('bankNameGroup');
        var bankInput = document.getElementById('bankName');
        function toggleBank() {
            if (!paymentType) return;
            var val = paymentType.value;
            var show = (val === '2' || val === '3');
            bankGroup.style.display = show ? 'block' : 'none';
            if (bankInput) bankInput.required = show;
            if (!show && bankInput) bankInput.value = '';
        }
        if (paymentType) {
            paymentType.addEventListener('change', toggleBank);
            toggleBank();
        }
    })();
</script>
