@using SmartHotelManagement.Model
@model IEnumerable<Room>

@{
    ViewData["HeaderTitle"] = "Room";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Rooms List"; // Updated this line
}

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <!-- Bootstrap 4 close button -->
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete <strong id="RoomDataTable"></strong>?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <a class="btn btn-primary mb-3" asp-action="Create">Add Room</a>
                </h3>
                <div class="card-body">
                    <style>
                        #RoomDataTable th,
                        #RoomDataTable td {
                            vertical-align: middle !important;
                            text-align: center;
                        }
                    </style>
                    <table id="RoomTable" class="table table-bordered table-striped">
                        
                        <thead>
                            <tr>
                                <th>Room Image</th>
                                <th>Room No</th>
                                <th>Room Type</th>
                                <th>Rate</th>                               
                                <th>Status</th>
                                <th>Active</th>
                                <th style="width:240px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>                                   
                                    <td>
                                        <img src="@(!string.IsNullOrEmpty(item.RoomImage) ? item.RoomImage : "/images/no-image.png")"
                                             style="width:70px;height:50px;border-radius:8px;object-fit:cover;" />
                                    </td>                                   
                                    <td>@item.RoomNumber</td>
                                    <td>@item.RoomType?.RoomTypeName</td>
                                    <td>@item.BaseRate.ToString("C")</td>
                                    <td>
                                        <span class="badge bg-secondary">@item.Status</span>
                                    </td>
                                    <td>@(item.IsActive ? "Yes" : "No")</td>
                                    <td>
                                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.RoomId">Edit</a>
                                        <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@item.RoomId">View Details</a>
                                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.RoomId">Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <!-- jQuery -->
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables -->
    <script src="~/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
    <script>
        $("#RoomTable").DataTable({
            "responsive": true,
            "autoWidth": false,
        });
    </script>

    <!--JS for Delete Modal (use jQuery .on for Bootstrap 4 events)-->
    <script>
        $(function () {
            $('#deleteModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget); // Button that triggered the modal
                var roomId = button.data('id');
                var roomName = button.data('name');

                $('#guestName').text(roomName);

                // Build action using Url.Action to ensure correct controller route
                var baseUrl = '@Url.Action("Delete", "Room")'; // e.g. "/Room/Delete"
                $('#deleteForm').attr('action', baseUrl + '/' + roomId);
            });
        });
    </script>
}
