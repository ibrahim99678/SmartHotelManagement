@model IEnumerable<SmartHotelManagement.Model.FinancialTransaction>
@{
    ViewData["HeaderTitle"] = "Income";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Income";
}
<div class="row">
    <div class="col">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">Income</h3>
                <div>
                    <a class="btn btn-primary" asp-action="AddIncome">Add Income</a>
                </div>
            </div>
            <div class="card-body">
                <form class="mb-3" method="get">
                    <div class="form-row">
                        <div class="col-md-2">
                            <label>Start</label>
                            <input type="date" name="start" value="@(((DateTime)ViewBag.Start).ToString("yyyy-MM-dd"))" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label>End</label>
                            <input type="date" name="end" value="@(((DateTime)ViewBag.End).ToString("yyyy-MM-dd"))" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label>Category</label>
                            <select name="categoryId" class="form-control" asp-items="ViewBag.CategoryId">
                                <option value="">All</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label>Payment Method</label>
                            <select name="paymentMethodId" class="form-control" asp-items="ViewBag.PaymentMethodId">
                                <option value="">All</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label>Reservation</label>
                            <select name="reservationId" class="form-control" asp-items="ViewBag.ReservationId">
                                <option value="">All</option>
                            </select>
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-secondary btn-block">Filter</button>
                        </div>
                    </div>
                </form>
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Currency</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td>@x.Date.ToString("g")</td>
                                <td>@x.Amount.ToString("C")</td>
                                <td>@x.Currency</td>
                                <td>@x.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
