@model IEnumerable<SmartHotelManagement.Model.FinancialTransaction>
@{
    ViewData["HeaderTitle"] = "Recurring Templates";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Recurring";
}
<div class="row">
    <div class="col">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">Recurring Transactions</h3>
                <form asp-action="GenerateRecurring" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-secondary">Generate for Current Period</button>
                </form>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Currency</th>
                            <th>CategoryId</th>
                            <th>PaymentMethodId</th>
                            <th>Rule</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td>@x.Type</td>
                                <td>@x.Date.ToShortDateString()</td>
                                <td>@x.Amount.ToString("C")</td>
                                <td>@x.Currency</td>
                                <td>@x.CategoryId</td>
                                <td>@x.PaymentMethodId</td>
                                <td>@x.RecurrenceRule</td>
                                <td>@x.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
