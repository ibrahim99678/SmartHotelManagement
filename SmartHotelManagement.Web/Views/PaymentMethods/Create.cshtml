@model SmartHotelManagement.Model.PaymentMethod
@{
    ViewData["HeaderTitle"] = "Add Payment Method";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Payment Method Add";
}
<div class="row">
    <div class="col-md-12">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">Add Payment Method</h3>
            </div>
            <form class="form-horizontal" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Name">Name</label>
                        <div class="col-sm-10">
                            <input asp-for="Name" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="Provider">Provider</label>
                        <div class="col-sm-10">
                            <input asp-for="Provider" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label" asp-for="MaskedAccount">Masked Account</label>
                        <div class="col-sm-10">
                            <input asp-for="MaskedAccount" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-2"></div>
                        <div class="col-sm-10">
                            <div class="form-check">
                                <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-info">Save</button>
                    <a asp-action="Index" class="btn btn-default float-right">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>
